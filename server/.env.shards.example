# Cloud erasure shards (R2 + Backblaze B2 + IDrive e2)
# Copy to server/.env.shards and fill in real values. Do NOT commit secrets.

FILE_STORAGE=shards

# Cloudflare R2
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=homeshare-shards-r2

# Backblaze B2
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=homeshare-shards-b2
B2_REGION=us-east-005

# IDrive e2
E2_ENDPOINT=https://s3.us-midwest-1.idrivee2.com
E2_ACCESS_KEY_ID=
E2_SECRET_ACCESS_KEY=
E2_BUCKET=homeshare-shards-e2
E2_REGION=us-midwest-1
