# Copy to .env and fill in values, then: npm install && npm start
FILE_STORAGE=disk
PORT=8080
CLIENT_URL=https://aluxie07.github.io/IWP-HomeShare
ALLOWED_ORIGINS=https://aluxie07.github.io/IWP-HomeShare,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080
JWT_SECRET=replace-with-a-long-random-string
MONGO_URI="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/homeshare"
SKIP_RECAPTCHA=true

# Optional — promote this account to admin on first login:
# ADMIN_EMAIL=you@example.com
